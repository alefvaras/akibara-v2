{
  "name": "akibara-quality-gates",
  "version": "1.0.0",
  "description": "Akibara — JS/CSS lint + E2E Playwright @critical golden flow",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint:js": "eslint 'wp-content/themes/akibara/assets/js/**/*.js' 'wp-content/plugins/akibara*/**/*.js'",
    "lint:css": "stylelint 'wp-content/themes/akibara/assets/css/**/*.css' 'wp-content/plugins/akibara*/**/*.css'",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,css,json,md}' --ignore-path .gitignore",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,css,json,md}' --ignore-path .gitignore",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test --grep @critical",
    "test:e2e:headed": "playwright test --headed --grep @critical",
    "test:e2e:admin": "playwright test --project=admin --project=admin-setup",
    "test:e2e:admin:headed": "playwright test --project=admin --project=admin-setup --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@wordpress/eslint-plugin": "^21.4.0",
    "@wordpress/prettier-config": "^4.18.0",
    "@wordpress/stylelint-config": "^23.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "stylelint": "^16.10.0",
    "stylelint-config-recommended": "^14.0.1"
  }
}
