# Local data + secrets
.env
.private/
# Solo /data/ root (docker-compose mariadb mount), NO subdir data/ dentro de plugins.
/data/

# Prod secrets — wp-config-private.php vive solo en server (chmod 600)
# Si por alguna razón llega local (debug, descarga), nunca commit.
wp-config-private.php
wp-config.php
**/wp-config-private.php
**/wp-config.php

# MCP config holds Royal API key in headers — never commit
.mcp.json

# Snapshots and audit raw output (heavy)
snapshots/
audit/raw/

# Mirror is fetched, not committed
server-snapshot/

# OS / IDE
.DS_Store
.vscode/
.idea/

# Local Claude Code overrides
.claude/settings.local.json

# Common build artifacts
node_modules/
vendor/
*.log
coverage/
.phpunit.cache/
playwright-report/
test-results/
.staging-agents/
