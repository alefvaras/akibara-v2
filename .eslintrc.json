{
  "root": true,
  "extends": ["plugin:@wordpress/eslint-plugin/recommended"],
  "env": {
    "browser": true,
    "es2022": true,
    "jquery": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "globals": {
    "wp": "readonly",
    "wc": "readonly",
    "wpApiSettings": "readonly",
    "akibara": "readonly",
    "akb": "readonly"
  },
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error"] }]
  },
  "ignorePatterns": [
    "node_modules/",
    "vendor/",
    "wp-content/plugins/akibara/coverage/",
    "wp-content/plugins/akibara/tests/",
    "wp-content/plugins/akibara/vendor/",
    "wp-content/themes/akibara/assets/js/**/*.min.js",
    ".private/",
    "audit/",
    "server-snapshot/",
    "data/",
    "test-results/",
    "playwright-report/"
  ]
}
