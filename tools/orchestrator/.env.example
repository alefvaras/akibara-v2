# Akibara Orchestrator — environment configuration
# Copy to .env and fill in real values. .env is gitignored.

# ── Anthropic API (REQUIRED) ──────────────────────────────────────
AKIBARA_ORCH_ANTHROPIC_API_KEY=sk-ant-...
AKIBARA_ORCH_ANTHROPIC_MODEL=claude-opus-4-5
AKIBARA_ORCH_ANTHROPIC_MAX_TOKENS=8192
AKIBARA_ORCH_ANTHROPIC_TEMPERATURE=0.7

# ── GitHub (gh CLI fallback if empty) ─────────────────────────────
AKIBARA_ORCH_GITHUB_TOKEN=ghp_...

# ── Discord webhook (optional, notifications) ─────────────────────
AKIBARA_ORCH_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# ── Brevo API (optional, emails) ──────────────────────────────────
AKIBARA_ORCH_BREVO_API_KEY=

# ── Sentry DSN (optional, agent error tracking) ───────────────────
AKIBARA_ORCH_SENTRY_DSN=

# ── Akibara connection ────────────────────────────────────────────
AKIBARA_ORCH_AKIBARA_SSH_ALIAS=akibara
AKIBARA_ORCH_AKIBARA_PROD_URL=https://akibara.cl
AKIBARA_ORCH_AKIBARA_STAGING_URL=https://staging.akibara.cl

# ── Dashboard ─────────────────────────────────────────────────────
AKIBARA_ORCH_DASHBOARD_HOST=127.0.0.1
AKIBARA_ORCH_DASHBOARD_PORT=8765
AKIBARA_ORCH_DASHBOARD_SECRET=change-this-token-in-prod

# ── Scheduler crons (default: daily/weekly) ───────────────────────
AKIBARA_ORCH_SCHEDULER_ENABLED=true
AKIBARA_ORCH_SEO_AUDIT_CRON="0 6 * * *"
AKIBARA_ORCH_SENTRY_DIGEST_CRON="0 14 * * *"
AKIBARA_ORCH_DEPS_CHECK_CRON="0 9 * * 1"

# ── Cost guardrails ───────────────────────────────────────────────
AKIBARA_ORCH_MAX_COST_PER_DAY_USD=10.0
AKIBARA_ORCH_MAX_TOKENS_PER_MINUTE=20000

# ── Logging ───────────────────────────────────────────────────────
AKIBARA_ORCH_LOG_LEVEL=INFO
AKIBARA_ORCH_LOG_FORMAT=json
