#!/usr/bin/env bash
# Manage SSH tunnel localhost:3308 -> akibara:127.0.0.1:3306
# Usage: bin/db-tunnel up|down|status

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
ENV_FILE="$PROJECT_DIR/.env"
[ -f "$ENV_FILE" ] && set -a && . "$ENV_FILE" && set +a

PORT="${PROD_DB_TUNNEL_PORT:-3308}"
TARGET_HOST="${PROD_DB_HOST:-127.0.0.1}"

is_up() {
  pgrep -f "ssh.*${PORT}:${TARGET_HOST}:3306.*akibara" >/dev/null
}

cmd="${1:-status}"

case "$cmd" in
  up)
    if is_up; then
      echo "✅ Tunnel already up on localhost:${PORT}"
      exit 0
    fi
    if ssh -fNTL "${PORT}:${TARGET_HOST}:3306" \
        -o ServerAliveInterval=60 \
        -o ExitOnForwardFailure=yes \
        akibara
    then
      sleep 1
      if is_up; then
        echo "✅ Tunnel up: localhost:${PORT} -> akibara:${TARGET_HOST}:3306"
      else
        echo "⚠️  ssh -f returned 0 but no tunnel process found"
        exit 1
      fi
    else
      echo "❌ Failed to start tunnel"
      exit 1
    fi
    ;;
  down)
    pkill -f "ssh.*${PORT}:${TARGET_HOST}:3306.*akibara" && \
      echo "✅ Tunnel killed" || \
      echo "(no tunnel running)"
    ;;
  status)
    if is_up; then
      echo "✅ Tunnel UP on localhost:${PORT}"
      lsof -nP -iTCP:${PORT} -sTCP:LISTEN 2>/dev/null | tail -n +2
    else
      echo "❌ Tunnel DOWN"
    fi
    ;;
  *)
    echo "Usage: $0 {up|down|status}"
    exit 1
    ;;
esac
