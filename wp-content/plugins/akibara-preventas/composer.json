{
    "name": "akibara/akibara-preventas",
    "description": "Preventas + encargos + notificaciones de volúmenes/series para Akibara",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Akibara\\Preventas\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
