{
  "name": "akibara/core",
  "description": "Akibara Core — foundation plugin para addons. ServiceLocator + ModuleRegistry + Lifecycle hooks + 13 módulos foundation.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "php-stubs/wordpress-stubs": "^6.6",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "Akibara\\Core\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Akibara\\Core\\Tests\\": "tests/phpunit/",
      "Akibara\\Core\\Tests\\Unit\\": "tests/phpunit/Unit/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "phpstan": "vendor/bin/phpstan analyse --level=6 --no-progress",
    "phpcs": "vendor/bin/phpcs --standard=WordPress --extensions=php --ignore=vendor,tests,modules/*/assets,*.min.* .",
    "phpcbf": "vendor/bin/phpcbf --standard=WordPress --extensions=php --ignore=vendor,tests ."
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
