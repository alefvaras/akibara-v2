{
    "name": "akibara/akibara-inventario",
    "description": "Akibara Inventario — Stock, shipping (BlueX + 12 Horas) and back-in-stock addon",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Akibara\\Inventario\\": "src/"
        }
    },
    "scripts": {
        "lint": "phpcs --standard=WordPress src/ modules/ akibara-inventario.php",
        "analyse": "phpstan analyse src/ modules/ akibara-inventario.php --level=6"
    }
}
