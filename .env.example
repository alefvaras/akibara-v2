# Akibara V2 — local docker stack environment
# Copy to .env and fill in. .env is gitignored.

# MariaDB local (NOT prod credentials — these are local sandbox only)
MARIADB_ROOT_PASSWORD=akibara_root_local
MARIADB_DATABASE=akibara_local
MARIADB_USER=akibara
MARIADB_PASSWORD=akibara_local

# WordPress local (uses MARIADB_* above)
WP_TABLE_PREFIX=wp_

# Ports exposed on host
WP_HTTP_PORT=8080
MARIADB_PORT=3307
